#!/usr/bin/env zsh
# Sapling-style smartlog using only git.
#
# Self-contained: depends only on zsh and git, so it can be downloaded and run
# standalone — no other files from this repo are required.
#
# Differences from sapling's `sl`
#   - Single stack only: renders the CURRENT HEAD's first-parent draft chain plus
#     its public base. Sapling's smartlog renders EVERY draft branch as its own
#     stack through a full DAG renderer (renderdag) ordered by an internal
#     topo-sort; this script deliberately does not — other local branches and
#     draft heads won't appear. Output matches `\sl` exactly when you're working a
#     single branch (the common case).
#   - Long subjects are shown in full; sapling truncates them to the terminal
#     width with an ellipsis (so they match in a wide terminal, differ in a narrow
#     one).
#
# Layout
#   - Public base: the nearest public ancestor of HEAD. Candidate trunks are
#     REMOTE-tracking refs only (origin/HEAD, upstream/HEAD, origin/main,
#     origin/master, upstream/main, upstream/master); among those, the one whose
#     merge-base with HEAD is closest to HEAD wins (mirrors sapling's "nearest
#     public ancestor" and tolerates a stale fork remote). NOT @{u} or a local
#     branch — a pushed feature branch's @{u}, or the local main/master you're
#     sitting on, can equal HEAD and collapse the whole draft stack. @{u} then a
#     local main/master are last-resort fallbacks when no remote trunk exists.
#   - Drafts: first-parent commits in `HEAD ^merge_base`, newest first
#   - Public window: -n commits starting at base_ref (or merge_base if base
#     is ahead of HEAD's chain)
#
# Format per commit
#   <symbol>  <hash:10>  <reltime>  <author>  [<refs>]
#   │  <subject>
#   │
#   - Symbol: @ for HEAD, o otherwise
#   - Uncommitted changes (opt-in via -u/--uncommitted): when the working tree is
#     dirty, a synthetic "Uncommitted changes" node is drawn on top of HEAD. Its
#     header carries compact totals ("2 files, +69 -2"); its body is the per-file
#     bars from `git diff --stat HEAD`, with the stat's own trailing total dropped
#     (it lives in the header). Untracked files are folded into BOTH the totals and
#     the body via a throwaway index overlay (`git add -N` against a copy of the
#     index), so they show as new-file additions without touching the real index;
#     count and line totals come from that same diff, so header always matches body.
#     In the body, git leaves filenames uncolored; this script color-codes them by
#     change kind (classified via `git diff --raw`): new files green, deletions red,
#     submodule changes cyan, others left default. The @ marker moves to the node —
#     that's where the working copy is — and HEAD drops to o (keeps author/subject).
#   - Author: %al (email local-part, e.g. "junz")
#   - Refs: %D filtered to remote bookmarks plus the active local branch, shown
#     with a trailing "*" like sapling's active bookmark — but only when no remote
#     branch of the same name exists (else just the remote shows, e.g. master ->
#     origin/master); inactive local branches and tags are dropped
#   - Last draft's subject line uses ╭─╯ instead of │ to bend into column 0
#   - Final line is ~ (truncation indicator)
#   - Compact public nodes: a public commit that is NOT HEAD and was authored by
#     someone other than you renders metadata-only (no author, no subject line).
#     Mirrors sapling's `sl_use_short_header`: short header iff
#     `graphnode != @ && phase == public && username|email != author|email`.
#     (Source: builtin_static/production.rs.) So your own public commits and the
#     @ commit still show author + subject in full.
#
# Colors (ANSI; suppressed when stdout isn't a TTY or NO_COLOR is set)
#   - Draft hash: bright-yellow + bold (\e[93;1m) — applies to ALL drafts
#   - Public hash: yellow (\e[33m)
#   - HEAD's time/author/subject: magenta (\e[35m)
#   - Refs: remote bookmarks green (\e[32m); the active local branch (name*) yellow
#     (\e[33m). Mirrors sapling's [color] defaults sl.remote=green, sl.active=yellow
#     (builtin_static/production.rs)
#   - Uncommitted body filenames (-u): new files green (\e[32m), deletions red
#     (\e[31m), submodule changes cyan (\e[36m); git's own +/- stat graph
#     (green/red) is left intact
#   - Symbols (@/o) and lines (│ ╭─╯): default
#
# Relative time — mirrors sapling's `smartdate(date, 5400, age, simpledate)`:
#   - Elapsed <= 5400s (90 min): `age()` — walks scales year→second and uses the
#     smallest where n>=2 (or seconds always); "1" is singularized.
#     Boundaries: <120s → "N seconds ago"; <7200s → "N minutes ago" (n=2..119);
#     etc. Smartlog only ever reaches the seconds/minutes tiers due to threshold.
#   - Elapsed > 5400s (or future): `simpledate()` — uses CALENDAR-day diff
#     (not elapsed seconds) to pick "Today" / "Yesterday" / "<Weekday>" /
#     "<Mon> DD" / full date with HH:MM.
# Source (paths in facebook/sapling): eden/scm/sapling/ext/smartlog.py (simpledate),
#         eden/scm/sapling/templatefilters.py (age),
#         eden/scm/lib/config/loader/src/builtin_static/production.rs (sl_date_threshold).
#
# Iteration
#   `sl` is aliased to git-smartlog, so escape with `\sl` to invoke the real
#   sapling binary. To validate, compare BOTH rendered text AND raw ANSI codes:
#       diff <(\sl) <(git smartlog)
#       diff <(\sl --color=always | cat -v) <(script -q /dev/null git-smartlog | cat -v)
#   Sapling emits "[0;Nm" forms while this script uses "[Nm"; visually identical.

zmodload zsh/datetime  # provides $EPOCHSECONDS and builtin strftime (no fork)

PROG=${0:t}

function die {
    # Print an error message to stderr and exit.
    print -ru2 -- "$PROG: $1"
    exit 1
}

function usage {
    print -r -- "usage: $PROG [-u] [-n N] [--base REV]

Sapling-style smartlog using only git: the current branch's draft stack
drawn on top of its nearest public (pushed) base.

  -u, --uncommitted   show a synthetic node for uncommitted working-tree changes
  -n, --limit N       public commits to show, including the merge-base (default 1)
      --base REV      override the public base (default: nearest remote trunk, e.g.
                      origin/HEAD, origin/main, origin/master, upstream/main)
  -h, --help          show this help and exit"
}

# Self-contained option parsing. zparseopts is a zsh builtin, so no libraries are
# needed; -K keeps the ARG_LIMIT default when -n is not passed.
ARG_LIMIT=(1)
ARG_BASE=()
ARG_HELP=()
ARG_UNCOMMITTED=()
zparseopts -D -E -K -- \
    {n,-limit}:=ARG_LIMIT \
    -base:=ARG_BASE \
    {u,-uncommitted}=ARG_UNCOMMITTED \
    {h,-help}=ARG_HELP \
    || { usage >&2; exit 2; }

(( ${#ARG_HELP} )) && { usage; exit 0; }

function resolve_base {
    local arg=$1
    if [[ -n $arg ]]; then
        git rev-parse --verify "$arg" >/dev/null 2>&1 || return 1
        print -r -- "$arg"
        return 0
    fi
    # Candidate trunks are REMOTE-tracking refs only: "public" commits come from
    # what's been pushed, never from a local branch. A local main/master — or the
    # branch you're on — can sit at or ahead of HEAD, which would make its
    # merge-base with HEAD == HEAD and collapse the whole draft stack.
    # <remote>/HEAD resolves to e.g. origin/master, so normalize via --abbrev-ref.
    local -a candidates
    local ref
    for ref in origin/HEAD upstream/HEAD \
               origin/main origin/master upstream/main upstream/master; do
        git rev-parse --verify "$ref" >/dev/null 2>&1 || continue
        candidates+=("$(git rev-parse --abbrev-ref "$ref")")
    done
    candidates=(${(u)candidates})

    # Among candidates, pick the one whose merge-base with HEAD is closest to HEAD
    # (i.e. the most recent common ancestor) — the nearest public ancestor. This
    # tolerates a stale fork remote (e.g. origin/master behind upstream/main).
    local best= best_mb= mb
    for ref in $candidates; do
        mb=$(git merge-base HEAD "$ref" 2>/dev/null) || continue
        if [[ -z $best ]] || git merge-base --is-ancestor "$best_mb" "$mb"; then
            best=$ref
            best_mb=$mb
        fi
    done
    if [[ -n $best ]]; then
        print -r -- "$best"
        return 0
    fi

    # Fallbacks for a repo with no remote trunk (local-only, or non-standard
    # setup): the current branch's upstream, then a local main/master.
    local upstream
    if upstream=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null); then
        print -r -- "$upstream"
        return 0
    fi
    for ref in main master; do
        if git rev-parse --verify "$ref" >/dev/null 2>&1; then
            print -r -- "$ref"
            return 0
        fi
    done
    return 1
}

# Globals set once in main() to avoid per-commit recomputation.
typeset -g NOW TODAY_MIDNIGHT CURRENT_YEAR ACTIVE_BRANCH

# Helpers set REPLY instead of printing — avoids a $(...) subshell per call.

function age {
    # Mirrors sapling's `age` templatefilter: walks scales year→second, uses the
    # smallest where n>=2 (or seconds as fallback). Singularizes when n==1.
    local delta=$1
    (( delta < 1 )) && delta=1
    local scales=(31536000 2592000 604800 86400 3600 60 1)
    local names=(year month week day hour minute second)
    local i n unit
    for i in {1..7}; do
        n=$((delta / scales[i]))
        if (( n >= 2 || scales[i] == 1 )); then
            unit=${names[i]}
            (( n != 1 )) && unit="${unit}s"
            REPLY="${n} ${unit} ago"
            return
        fi
    done
}

function simpledate {
    # Mirrors sapling's `simpledate` templatefunc. Uses calendar-day diff, not
    # elapsed seconds, so 23:50 yesterday is "Yesterday" even when 20 min ago.
    local epoch=$1
    local hm
    strftime -s hm '%H:%M' $epoch

    if (( epoch > NOW )); then
        strftime -s REPLY '%Y-%m-%d %H:%M' $epoch
        return
    fi

    local commit_date commit_midnight td_days
    strftime -s commit_date '%Y-%m-%d' $epoch
    strftime -rs commit_midnight '%Y-%m-%d %H:%M:%S' "$commit_date 00:00:00"
    td_days=$(( (TODAY_MIDNIGHT - commit_midnight) / 86400 ))

    if (( td_days == 0 )); then
        REPLY="Today at ${hm}"
    elif (( td_days == 1 )); then
        REPLY="Yesterday at ${hm}"
    elif (( td_days <= 6 )); then
        local weekday
        strftime -s weekday '%A' $epoch
        REPLY="${weekday} at ${hm}"
    else
        local commit_year
        strftime -s commit_year '%Y' $epoch
        if [[ $commit_year == $CURRENT_YEAR ]] || (( td_days <= 90 )); then
            local md
            strftime -s md '%b %d' $epoch
            REPLY="${md} at ${hm}"
        else
            strftime -s REPLY '%Y-%m-%d %H:%M' $epoch
        fi
    fi
}

function reltime {
    # Mirrors sapling's smartlog template: smartdate(date, 5400, age, simpledate).
    local epoch=$1
    local diff=$((NOW - epoch))
    if (( diff >= 0 && diff <= 5400 )); then
        age $diff
    else
        simpledate $epoch
    fi
}

function filter_refs {
    # Operates on %D from `git log --decorate=full`, so every ref is a full path:
    #   "HEAD -> refs/heads/feat, refs/remotes/origin/feat, refs/tags/v1, ..."
    # Mirror what sapling shows: remote bookmarks (refs/remotes/*) plus the active
    # local branch as $ACTIVE_BRANCH ("name*"), precomputed in main(). Inactive
    # local branches and tags are hidden, as is the active branch when a remote of
    # the same name exists (sapling shows only the remote bookmark — e.g. `master`
    # yields just `origin/master`, never `master*`). sapling sorts names, so sort
    # alphabetically; join with a single space.
    local raw=$1
    REPLY=
    [[ -z $raw ]] && return
    local -a out
    local r
    for r in ${(@s:, :)raw}; do
        case $r in
            "HEAD -> "*)                                    # active branch (HEAD's)
                [[ -n $ACTIVE_BRANCH ]] && out+=("$ACTIVE_BRANCH") ;;
            HEAD) ;;                                        # detached-HEAD self-ref
            */HEAD) ;;                                      # remote default-branch pointer
            refs/heads/*) ;;                                # inactive local branch — hidden
            refs/tags/*) ;;                                 # tag — smartlog doesn't show tags
            refs/remotes/*) out+=("${r#refs/remotes/}") ;;  # remote bookmark → origin/master
            *) out+=("$r") ;;
        esac
    done
    out=(${(o)out})
    REPLY="${(j: :)out}"
}

function main {
    NOW=$EPOCHSECONDS
    local today
    strftime -s today '%Y-%m-%d' $NOW
    strftime -rs TODAY_MIDNIGHT '%Y-%m-%d %H:%M:%S' "$today 00:00:00"
    strftime -s CURRENT_YEAR '%Y' $NOW

    # For sapling's compact-public-node rule: a public, non-HEAD commit authored
    # by someone else renders metadata-only. Compared against the configured user.
    local my_email
    my_email=$(git config user.email 2>/dev/null)

    # The active local branch (HEAD's) is shown with a trailing "*", like sapling's
    # active bookmark — but only when no remote branch of the same name exists. If
    # one does, sapling shows just the remote bookmark (e.g. on `master`, only
    # origin/master appears, never master*). Detached HEAD has no active branch.
    ACTIVE_BRANCH=
    local cur_branch
    cur_branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null)
    if [[ -n $cur_branch ]] &&
       [[ -z $(git for-each-ref --count=1 --format=x "refs/remotes/*/${cur_branch}" 2>/dev/null) ]]; then
        ACTIVE_BRANCH="${cur_branch}*"
    fi

    local limit=${ARG_LIMIT[-1]}
    local base_arg=
    (( ${#ARG_BASE} > 0 )) && base_arg=${ARG_BASE[-1]}

    local base_ref
    if [[ -n $base_arg ]]; then
        base_ref=$(resolve_base "$base_arg") ||
            die "Cannot resolve --base $base_arg"
    else
        base_ref=$(resolve_base "") ||
            die "Cannot find a public base ref (no remote trunk, @{u}, or local main/master)"
    fi

    local head_sha
    head_sha=$(git rev-parse HEAD 2>/dev/null) ||
        die "HEAD is not a valid commit"

    local merge_base
    merge_base=$(git merge-base HEAD "$base_ref" 2>/dev/null) ||
        die "No merge-base between HEAD and $base_ref"

    # Working-directory changes render as a synthetic "Uncommitted changes" draft
    # node on top of HEAD; the @ marker moves there, since that's where the working
    # copy actually is. Capture status once and summarize file/line counts.
    local has_changes=0 wdir_summary=
    local -a wdir_stat
    local porcelain=
    (( ${#ARG_UNCOMMITTED} )) && porcelain=$(git status --porcelain 2>/dev/null)
    if [[ -n $porcelain ]]; then
        has_changes=1
        # `git diff HEAD` only sees tracked paths, so untracked files would be
        # missing from both the +/- totals and the per-file body. To fold them in
        # WITHOUT mutating the repo, copy the index to a throwaway file and
        # `git add -N` (intent-to-add) the untracked paths there: against that temp
        # index, `git diff HEAD` renders each untracked file as a new file with its
        # lines as additions, aligned with the tracked entries. GIT_INDEX_FILE keeps
        # the real index and working tree untouched. With no untracked files,
        # stat_index just points at the real index — a no-op.
        local untracked_raw=$(git ls-files --others --exclude-standard 2>/dev/null)
        local stat_index=$(git rev-parse --git-path index 2>/dev/null)
        local tmp_index=
        if [[ -n $untracked_raw ]]; then
            local -a untracked=("${(@f)untracked_raw}")
            tmp_index=$(mktemp)
            [[ -f $stat_index ]] && cp "$stat_index" "$tmp_index"
            GIT_INDEX_FILE=$tmp_index git add -N -- "${untracked[@]}" 2>/dev/null
            stat_index=$tmp_index
        fi
        # Compact totals for the header line. File count AND line totals come from
        # the same overlay diff, so the header always agrees with the body below
        # (an untracked directory expands to its individual files in both).
        local shortstat n_files=0 ins=0 del=0
        shortstat=$(GIT_INDEX_FILE=$stat_index git diff --shortstat HEAD 2>/dev/null)
        [[ $shortstat =~ '([0-9]+) files? changed' ]] && n_files=$match[1]
        [[ $shortstat =~ '([0-9]+) insertion' ]] && ins=$match[1]
        [[ $shortstat =~ '([0-9]+) deletion' ]] && del=$match[1]
        local file_word=files
        (( n_files == 1 )) && file_word=file
        wdir_summary="${n_files} ${file_word}"
        (( ins > 0 || del > 0 )) && wdir_summary+=", +${ins} -${del}"
        # Per-file body from `git diff --stat HEAD`, minus its trailing summary line
        # (those totals already sit in the header). Captured via $(...) so git uses
        # its stable non-TTY default width regardless of the caller's terminal —
        # which also strips its color, so force it back on when we're rendering in
        # color (matching the same TTY/NO_COLOR test as the C_* palette below).
        local stat_color=--color=never
        [[ -t 1 && -z $NO_COLOR ]] && stat_color=--color=always
        wdir_stat=("${(@f)$(GIT_INDEX_FILE=$stat_index git diff $stat_color --stat HEAD 2>/dev/null)}")
        (( ${#wdir_stat} > 0 )) && wdir_stat=("${(@)wdir_stat[1,-2]}")

        # Color-code the body filenames that git's --stat leaves plain: new files
        # (status A) green, deletions (status D) red, submodule changes (gitlink
        # mode 160000) cyan. Classify each path from `git diff --raw` against the
        # same overlay (submodule wins over A/D when both apply), then wrap just
        # the name chars in the matching stat line — git's own +/- graph coloring
        # (already in the captured line, after the '|') is left untouched. Only runs
        # when rendering in color, matching the stat_color gate above. Paths long
        # enough that git truncates the name column to "...tail" are matched by that
        # tail; anything unmatched simply keeps the default (uncolored) name.
        if [[ $stat_color == *always ]] && (( ${#wdir_stat} )); then
            local -A wdir_class
            local raw_line
            while IFS= read -r raw_line; do
                [[ -z $raw_line ]] && continue
                local -a mf=(${=${raw_line%%$'\t'*}})   # :oldmode newmode oldsha newsha STATUS
                local p=${raw_line##*$'\t'}             # path (new path for renames)
                if [[ ${mf[1]#:} == 160000 || ${mf[2]} == 160000 ]]; then
                    wdir_class[$p]=$'\e[36m'             # submodule -> cyan
                elif [[ ${mf[5]} == A* ]]; then
                    wdir_class[$p]=$'\e[32m'             # new file -> green
                elif [[ ${mf[5]} == D* ]]; then
                    wdir_class[$p]=$'\e[31m'             # deleted file -> red
                fi
            done < <(GIT_INDEX_FILE=$stat_index git diff --raw HEAD 2>/dev/null)

            if (( ${#wdir_class} )); then
                local creset=$'\e[0m'
                local -a recolored=()
                local sline= before= after= lead= body= trail= nf= col= cp=
                for sline in $wdir_stat; do
                    before=${sline%%\|*}            # " name<pad> " up to the first '|'
                    if [[ $before == $sline ]]; then
                        recolored+=("$sline"); continue   # no '|' (summary slack): keep
                    fi
                    after=${sline#"$before"}        # "| graph..." with git's colors
                    lead=${before%%[! ]*}           # leading spaces
                    body=${before#"$lead"}          # name + trailing pad
                    trail=${body##*[! ]}            # trailing spaces
                    nf=${body%"$trail"}             # the display name
                    col=${wdir_class[$nf]}
                    if [[ -z $col && $nf == ...* ]]; then   # truncated long path: match by tail
                        for cp in ${(k)wdir_class}; do
                            [[ $cp == *"${nf#...}" ]] && { col=${wdir_class[$cp]}; break }
                        done
                    fi
                    if [[ -n $col ]]; then
                        recolored+=("${lead}${col}${nf}${creset}${trail}${after}")
                    else
                        recolored+=("$sline")
                    fi
                done
                wdir_stat=("${recolored[@]}")
            fi
        fi
        [[ -n $tmp_index ]] && rm -f "$tmp_index"
    fi

    local -a drafts publics
    if [[ $head_sha != $merge_base ]]; then
        drafts=("${(@f)$(git rev-list --first-parent HEAD "^$merge_base")}")
    fi
    publics=("${(@f)$(git rev-list --first-parent "$base_ref" -n $limit)}")
    # If base_ref is ahead of HEAD's branch, anchor public column at merge_base instead.
    if [[ ${publics[(Ie)$merge_base]} -eq 0 ]]; then
        publics=("${(@f)$(git rev-list --first-parent "$merge_base" -n $limit)}")
    fi

    local C_PUBLIC_HASH= C_DRAFT_HASH= C_HEAD_TEXT= C_REF= C_BRANCH= C_RESET=
    if [[ -t 1 && -z $NO_COLOR ]]; then
        C_PUBLIC_HASH=$'\e[33m'
        C_DRAFT_HASH=$'\e[93;1m'
        C_HEAD_TEXT=$'\e[35m'
        C_REF=$'\e[32m'
        C_BRANCH=$'\e[33m'
        C_RESET=$'\e[0m'
    fi

    local -a all_shas
    all_shas=("${drafts[@]}" "${publics[@]}")
    (( ${#all_shas} == 0 )) && die "Nothing to display"

    local commit_data
    commit_data=$(git log --no-walk=unsorted --abbrev=10 --decorate=full \
        --pretty=format:'%h%x1f%at%x1f%al%x1f%ae%x1f%D%x1f%s' "${all_shas[@]}")

    local -a hashes epochs authors author_emails refs subjects
    local h e a ae r s
    while IFS=$'\x1f' read -r h e a ae r s; do
        [[ -z $h ]] && continue
        hashes+=("$h")
        epochs+=("$e")
        authors+=("$a")
        author_emails+=("$ae")
        refs+=("$r")
        subjects+=("$s")
    done <<< "$commit_data"

    local n_drafts=${#drafts}
    local total=$((n_drafts + ${#publics}))

    # Synthetic wdir node, drawn above the stack: @ marker, draft-colored label, the
    # change summary in HEAD-text color. It connects straight down into the draft
    # column when HEAD is a draft, otherwise it bends (╭─╯) into the public column.
    if (( has_changes )); then
        local wdir_text_reset=
        [[ -n $C_HEAD_TEXT ]] && wdir_text_reset=$C_RESET
        print -r -- "  @  ${C_DRAFT_HASH}Uncommitted changes${C_RESET}${C_HEAD_TEXT}  ${wdir_summary}${wdir_text_reset}"
        local stat_line
        for stat_line in $wdir_stat; do
            print -r -- "  │${stat_line}"
        done
        if (( n_drafts > 0 )); then
            print -r -- "  │"
        else
            print -r -- "╭─╯"
            print -r -- "│"
        fi
    fi

    local i
    for ((i=1; i<=total; i++)); do
        local sha=${all_shas[$i]}
        local hash=${hashes[$i]}
        local epoch=${epochs[$i]}
        local author=${authors[$i]}
        local author_email=${author_emails[$i]}
        local refs_raw=${refs[$i]}
        local subject=${subjects[$i]}

        local is_draft=0 is_last_draft=0 is_last_public=0
        (( i <= n_drafts )) && is_draft=1
        (( i == n_drafts && n_drafts > 0 )) && is_last_draft=1
        (( i == total )) && is_last_public=1

        local symbol=o
        local hash_color=$C_PUBLIC_HASH
        local text_color=
        (( is_draft )) && hash_color=$C_DRAFT_HASH
        local is_head=0
        if [[ $sha == $head_sha ]]; then
            is_head=1
            # With uncommitted changes the @ marker belongs to the wdir node above;
            # HEAD stays a normal node (but is_head still forces a full, non-compact
            # header so its author/subject keep showing).
            if (( ! has_changes )); then
                symbol=@
                text_color=$C_HEAD_TEXT
            fi
        fi

        # Compact public node: public (not a draft), not HEAD, authored by someone
        # else → metadata-only (no author, no subject). See header.
        local is_compact=0
        if (( ! is_draft && ! is_head )) && [[ $author_email != $my_email ]]; then
            is_compact=1
        fi

        reltime $epoch
        local time_str=$REPLY
        filter_refs "$refs_raw"
        local refs_clean=$REPLY
        local ref_display=
        if [[ -n $refs_clean ]]; then
            # Color each ref by kind, matching sapling: the active local branch
            # ($ACTIVE_BRANCH, the "name*" token) is yellow, remote bookmarks green.
            # Quote the RHS so the trailing "*" is matched literally, not as a glob.
            # Both locals MUST carry an assignment: a bare `local rt` / `local -a
            # colored` re-run in the same function scope neither resets the prior
            # iteration's value nor stays silent — zsh echoes the stale value.
            local -a colored=()
            local rt=
            for rt in ${(s: :)refs_clean}; do
                if [[ $rt == "$ACTIVE_BRANCH" ]]; then
                    colored+=("${C_BRANCH}${rt}${C_RESET}")
                else
                    colored+=("${C_REF}${rt}${C_RESET}")
                fi
            done
            ref_display="  ${(j: :)colored}"
        fi

        local indent=
        (( is_draft )) && indent="  "

        local text_reset=
        [[ -n $text_color ]] && text_reset=$C_RESET

        local author_seg="  ${author}"
        (( is_compact )) && author_seg=
        local subject_body="  ${text_color}${subject}${text_reset}"
        (( is_compact )) && subject_body=

        print -r -- "${indent}${symbol}  ${hash_color}${hash}${C_RESET}${text_color}  ${time_str}${author_seg}${text_reset}${ref_display}"

        if (( is_last_draft )); then
            print -r -- "╭─╯${subject_body}"
            print -r -- "│"
        elif (( is_last_public )); then
            print -r -- "${indent}│${subject_body}"
            print -r -- "~"
        else
            print -r -- "${indent}│${subject_body}"
            print -r -- "${indent}│"
        fi
    done
}

main
