#!/usr/bin/env zsh
# Sapling-style smartlog using only git.
#
# Self-contained: a single file depending only on zsh and git, so it can be
# downloaded and run standalone — no other files from this repo are required. The
# -u (uncommitted changes) node needs nothing external either: its stat block is
# computed by the in-file `uncommitted_stat` function.
#
# Multi-call: this same file is also `git-smartstat`. Symlink it under that name
# (e.g. `ln -s git-smartlog git-smartstat`) and the git-smartstat name runs ONLY
# the uncommitted-changes stat — the exact body that -u draws — as a standalone
# command (`git smartstat`). Dispatch is on the invocation name ($PROG) at the
# bottom; both names share `uncommitted_stat`, so there's no duplicated logic.
#
# Differences from sapling's `sl`
#   - Single stack only: renders the CURRENT HEAD's first-parent draft chain plus
#     its public base. Sapling's smartlog renders EVERY draft branch as its own
#     stack through a full DAG renderer (renderdag) ordered by an internal
#     topo-sort; this script deliberately does not — other local branches and
#     draft heads won't appear. Output matches `\sl` exactly when you're working a
#     single branch (the common case).
#   - Long subjects are shown in full; sapling truncates them to the terminal
#     width with an ellipsis (so they match in a wide terminal, differ in a narrow
#     one).
#
# Layout
#   - Public base: the nearest public ancestor of HEAD. Candidate trunks are
#     REMOTE-tracking refs only (origin/HEAD, upstream/HEAD, origin/main,
#     origin/master, upstream/main, upstream/master); among those, the one whose
#     merge-base with HEAD is closest to HEAD wins (mirrors sapling's "nearest
#     public ancestor" and tolerates a stale fork remote). NOT @{u} or a local
#     branch — a pushed feature branch's @{u}, or the local main/master you're
#     sitting on, can equal HEAD and collapse the whole draft stack. @{u} then a
#     local main/master are last-resort fallbacks when no remote trunk exists.
#   - Drafts: first-parent commits in `HEAD ^merge_base`, newest first
#   - Public window: -n commits starting at base_ref (or merge_base if base
#     is ahead of HEAD's chain)
#
# Format per commit
#   <symbol>  <hash:10>  <reltime>  <author>  [<refs>]
#   │  <subject>
#   │
#   - Symbol: @ for HEAD, o otherwise
#   - Uncommitted changes (opt-in via -u/--uncommitted): when the working tree is
#     dirty, a synthetic "Uncommitted changes" node is drawn on top of HEAD. Its
#     header carries compact totals ("2 files, +69 -2"); its body is the per-file
#     bars from `git diff --stat HEAD`, with the stat's own trailing total dropped
#     (it lives in the header). Loose untracked files are folded into BOTH the
#     totals and the body via a throwaway index overlay (`git add -N` against a copy
#     of the index), so they show as new-file additions without touching the real
#     index. A wholly-untracked directory is NOT expanded: like `git status` it
#     collapses to a single "dir/ | N files" body line — counted as one file in the
#     totals, contributing no +/- lines. The header still matches the body: one
#     counted entry per body line.
#     Each body filename is prefixed with a one-letter change marker (from
#     `git diff --raw`, plus porcelain for conflicts): A added, ? untracked,
#     M modified, D deleted, R renamed, T typechange, S submodule, U unmerged;
#     marker and name are colored by kind (see the Colors note below), and an
#     executable-bit flip gets a trailing +x/-x hint. The body is grouped by marker
#     in that order (A ? M D R T S U), alphabetical within each group. The @ marker
#     moves to the node — that's where the working copy is — and HEAD drops to o
#     (keeps author/subject).
#   - Author: %al (email local-part, e.g. "junz")
#   - Refs: %D filtered to remote bookmarks plus the active local branch, shown
#     with a trailing "*" like sapling's active bookmark — but only when no remote
#     branch of the same name exists (else just the remote shows, e.g. master ->
#     origin/master); inactive local branches and tags are dropped
#   - Last draft's subject line uses ╭─╯ instead of │ to bend into column 0
#   - Final line is ~ (truncation indicator)
#   - Compact public nodes: a public commit that is NOT HEAD and was authored by
#     someone other than you renders metadata-only (no author, no subject line).
#     Mirrors sapling's `sl_use_short_header`: short header iff
#     `graphnode != @ && phase == public && username|email != author|email`.
#     (Source: builtin_static/production.rs.) So your own public commits and the
#     @ commit still show author + subject in full.
#
# Colors (ANSI; suppressed when stdout isn't a TTY or NO_COLOR is set)
#   - Draft hash: bright-yellow + bold (\e[93;1m) — applies to ALL drafts
#   - Public hash: yellow (\e[33m)
#   - HEAD's time/author/subject: magenta (\e[35m)
#   - Refs: remote bookmarks green (\e[32m); the active local branch (name*) yellow
#     (\e[33m). Mirrors sapling's [color] defaults sl.remote=green, sl.active=yellow
#     (builtin_static/production.rs)
#   - Uncommitted body (-u): a change marker prefixes each filename; marker and name
#     are colored by kind — A added green (\e[32m), ? untracked dim green (\e[2;32m),
#     D deleted red (\e[31m), R/C renamed blue (\e[34m), T typechange magenta
#     (\e[35m), S submodule cyan (\e[36m), U unmerged bold red (\e[1;31m); M modified
#     and the rest default. A +x/-x hint (dim) flags executable-bit flips. git's own
#     +/- stat graph (green/red) after the '|' is left intact
#   - Symbols (@/o) and lines (│ ╭─╯): default
#
# Relative time — mirrors sapling's `smartdate(date, 5400, age, simpledate)`:
#   - Elapsed <= 5400s (90 min): `age()` — walks scales year→second and uses the
#     smallest where n>=2 (or seconds always); "1" is singularized.
#     Boundaries: <120s → "N seconds ago"; <7200s → "N minutes ago" (n=2..119);
#     etc. Smartlog only ever reaches the seconds/minutes tiers due to threshold.
#   - Elapsed > 5400s (or future): `simpledate()` — uses CALENDAR-day diff
#     (not elapsed seconds) to pick "Today" / "Yesterday" / "<Weekday>" /
#     "<Mon> DD" / full date with HH:MM.
# Source (paths in facebook/sapling): eden/scm/sapling/ext/smartlog.py (simpledate),
#         eden/scm/sapling/templatefilters.py (age),
#         eden/scm/lib/config/loader/src/builtin_static/production.rs (sl_date_threshold).
#
# Iteration
#   `sl` is aliased to git-smartlog, so escape with `\sl` to invoke the real
#   sapling binary. To validate, compare BOTH rendered text AND raw ANSI codes:
#       diff <(\sl) <(git smartlog)
#       diff <(\sl --color=always | cat -v) <(script -q /dev/null git-smartlog | cat -v)
#   Sapling emits "[0;Nm" forms while this script uses "[Nm"; visually identical.

zmodload zsh/datetime  # provides $EPOCHSECONDS and builtin strftime (no fork)

PROG=${0:t}

function die {
    # Print an error message to stderr and exit.
    print -ru2 -- "$PROG: $1"
    exit 1
}

function smartlog_usage {
    print -r -- "usage: $PROG [-u] [-n N] [--base REV]

Sapling-style smartlog using only git: the current branch's draft stack
drawn on top of its nearest public (pushed) base.

  -u, --uncommitted   show a synthetic node for uncommitted working-tree changes
  -n, --limit N       public commits to show, including the merge-base (default 1)
      --base REV      override the public base (default: nearest remote trunk, e.g.
                      origin/HEAD, origin/main, origin/master, upstream/main)
  -h, --help          show this help and exit"
}

function smartstat_usage {
    print -r -- "usage: $PROG [--color WHEN]

Show uncommitted working-tree changes as a compact stat block: a summary line
(\"2 files, +69 -2\") followed by per-file diff bars; loose untracked files are
folded in and wholly-untracked directories collapse to a single entry like git
status. Each name carries a change marker — A added, ? untracked, M modified,
D deleted, R renamed, T typechange, S submodule, U unmerged — colored by kind.
Prints nothing when the working tree is clean. The same block git-smartlog -u draws.

      --color WHEN    colorize output: auto (default), always, or never
  -h, --help          show this help and exit"
}

function resolve_base {
    local arg=$1
    if [[ -n $arg ]]; then
        git rev-parse --verify "$arg" >/dev/null 2>&1 || return 1
        print -r -- "$arg"
        return 0
    fi
    # Candidate trunks are REMOTE-tracking refs only: "public" commits come from
    # what's been pushed, never from a local branch. A local main/master — or the
    # branch you're on — can sit at or ahead of HEAD, which would make its
    # merge-base with HEAD == HEAD and collapse the whole draft stack.
    # <remote>/HEAD resolves to e.g. origin/master, so normalize via --abbrev-ref.
    local -a candidates
    local ref
    for ref in origin/HEAD upstream/HEAD \
               origin/main origin/master upstream/main upstream/master; do
        git rev-parse --verify "$ref" >/dev/null 2>&1 || continue
        candidates+=("$(git rev-parse --abbrev-ref "$ref")")
    done
    candidates=(${(u)candidates})

    # Among candidates, pick the one whose merge-base with HEAD is closest to HEAD
    # (i.e. the most recent common ancestor) — the nearest public ancestor. This
    # tolerates a stale fork remote (e.g. origin/master behind upstream/main).
    local best= best_mb= mb
    for ref in $candidates; do
        mb=$(git merge-base HEAD "$ref" 2>/dev/null) || continue
        if [[ -z $best ]] || git merge-base --is-ancestor "$best_mb" "$mb"; then
            best=$ref
            best_mb=$mb
        fi
    done
    if [[ -n $best ]]; then
        print -r -- "$best"
        return 0
    fi

    # Fallbacks for a repo with no remote trunk (local-only, or non-standard
    # setup): the current branch's upstream, then a local main/master.
    local upstream
    if upstream=$(git rev-parse --abbrev-ref --symbolic-full-name '@{u}' 2>/dev/null); then
        print -r -- "$upstream"
        return 0
    fi
    for ref in main master; do
        if git rev-parse --verify "$ref" >/dev/null 2>&1; then
            print -r -- "$ref"
            return 0
        fi
    done
    return 1
}

# Globals set once in main() to avoid per-commit recomputation.
typeset -g NOW TODAY_MIDNIGHT CURRENT_YEAR ACTIVE_BRANCH

# uncommitted_stat()'s outputs (REPLY-style globals, read by both entry points).
typeset -g STAT_HAS_CHANGES STAT_SUMMARY
typeset -ga STAT_BODY

# Helpers set REPLY instead of printing — avoids a $(...) subshell per call.

function age {
    # Mirrors sapling's `age` templatefilter: walks scales year→second, uses the
    # smallest where n>=2 (or seconds as fallback). Singularizes when n==1.
    local delta=$1
    (( delta < 1 )) && delta=1
    local scales=(31536000 2592000 604800 86400 3600 60 1)
    local names=(year month week day hour minute second)
    local i n unit
    for i in {1..7}; do
        n=$((delta / scales[i]))
        if (( n >= 2 || scales[i] == 1 )); then
            unit=${names[i]}
            (( n != 1 )) && unit="${unit}s"
            REPLY="${n} ${unit} ago"
            return
        fi
    done
}

function simpledate {
    # Mirrors sapling's `simpledate` templatefunc. Uses calendar-day diff, not
    # elapsed seconds, so 23:50 yesterday is "Yesterday" even when 20 min ago.
    local epoch=$1
    local hm
    strftime -s hm '%H:%M' $epoch

    if (( epoch > NOW )); then
        strftime -s REPLY '%Y-%m-%d %H:%M' $epoch
        return
    fi

    local commit_date commit_midnight td_days
    strftime -s commit_date '%Y-%m-%d' $epoch
    strftime -rs commit_midnight '%Y-%m-%d %H:%M:%S' "$commit_date 00:00:00"
    td_days=$(( (TODAY_MIDNIGHT - commit_midnight) / 86400 ))

    if (( td_days == 0 )); then
        REPLY="Today at ${hm}"
    elif (( td_days == 1 )); then
        REPLY="Yesterday at ${hm}"
    elif (( td_days <= 6 )); then
        local weekday
        strftime -s weekday '%A' $epoch
        REPLY="${weekday} at ${hm}"
    else
        local commit_year
        strftime -s commit_year '%Y' $epoch
        if [[ $commit_year == $CURRENT_YEAR ]] || (( td_days <= 90 )); then
            local md
            strftime -s md '%b %d' $epoch
            REPLY="${md} at ${hm}"
        else
            strftime -s REPLY '%Y-%m-%d %H:%M' $epoch
        fi
    fi
}

function reltime {
    # Mirrors sapling's smartlog template: smartdate(date, 5400, age, simpledate).
    local epoch=$1
    local diff=$((NOW - epoch))
    if (( diff >= 0 && diff <= 5400 )); then
        age $diff
    else
        simpledate $epoch
    fi
}

function filter_refs {
    # Operates on %D from `git log --decorate=full`, so every ref is a full path:
    #   "HEAD -> refs/heads/feat, refs/remotes/origin/feat, refs/tags/v1, ..."
    # Mirror what sapling shows: remote bookmarks (refs/remotes/*) plus the active
    # local branch as $ACTIVE_BRANCH ("name*"), precomputed in main(). Inactive
    # local branches and tags are hidden, as is the active branch when a remote of
    # the same name exists (sapling shows only the remote bookmark — e.g. `master`
    # yields just `origin/master`, never `master*`). sapling sorts names, so sort
    # alphabetically; join with a single space.
    local raw=$1
    REPLY=
    [[ -z $raw ]] && return
    local -a out
    local r
    for r in ${(@s:, :)raw}; do
        case $r in
            "HEAD -> "*)                                    # active branch (HEAD's)
                [[ -n $ACTIVE_BRANCH ]] && out+=("$ACTIVE_BRANCH") ;;
            HEAD) ;;                                        # detached-HEAD self-ref
            */HEAD) ;;                                      # remote default-branch pointer
            refs/heads/*) ;;                                # inactive local branch — hidden
            refs/tags/*) ;;                                 # tag — smartlog doesn't show tags
            refs/remotes/*) out+=("${r#refs/remotes/}") ;;  # remote bookmark → origin/master
            *) out+=("$r") ;;
        esac
    done
    out=(${(o)out})
    REPLY="${(j: :)out}"
}

function uncommitted_stat {
    # Compute the uncommitted-changes stat block. $1 = color_on (1 to colorize the
    # marker/name and request colored +/- bars from git; 0 for plain). Sets globals
    # STAT_HAS_CHANGES (0/1), STAT_SUMMARY (a plain "N files, +X -Y" string — never
    # colored, the caller styles it) and STAT_BODY (per-file body lines, marked and,
    # when color_on, colored). Reads the working tree only; never mutates the real
    # index. Shared by `git-smartlog -u` and standalone `git-smartstat`.
    local color_on=$1
    local reserve=${2:-0}   # columns the caller will prepend to each body line
    STAT_HAS_CHANGES=0
    STAT_SUMMARY=
    STAT_BODY=()

    # Width for the `git diff --stat` body. It's captured via $(...) below, so git
    # sees a pipe and would pin to its 80-column non-TTY default — truncating long
    # paths to "...tail" no matter how wide the real terminal is. When OUR stdout is
    # a terminal, probe its width and pass it through, so paths show in full when
    # there's room; git still truncates to fit a narrow terminal. Piped output stays
    # at 80, keeping captures stable. The width comes from the controlling terminal
    # (`stty size </dev/tty`) — not `<&1`, which inside $(...) is the capture pipe,
    # not the tty — with $COLUMNS as a fallback.
    local stat_width=80
    if [[ -t 1 ]]; then
        local termsize=
        termsize=$(stty size </dev/tty 2>/dev/null)   # "rows cols"
        if [[ $termsize == <->" "<-> ]]; then
            stat_width=${termsize##* }
        elif [[ -n $COLUMNS ]] && (( COLUMNS >= 20 )); then
            stat_width=$COLUMNS
        fi
        # Leave room for the caller's per-line prefix (the -u node indents the body
        # by "  │ "); piped output has no terminal to overflow, so it keeps 80.
        (( stat_width -= reserve ))
        (( stat_width < 20 )) && stat_width=20
    fi

    local porcelain=$(git status --porcelain 2>/dev/null)
    [[ -z $porcelain ]] && return
    STAT_HAS_CHANGES=1

    # Diff against HEAD, or git's empty-tree object when HEAD is unborn (a repo with
    # no commits) so staged/untracked files still show as additions.
    local diff_target=HEAD
    git rev-parse --verify --quiet HEAD >/dev/null 2>&1 ||
        diff_target=4b825dc642cb6eb9a060e54bf8d69288fbee4904

    # Untracked entries via `git ls-files --directory`: a wholly-untracked directory
    # folds to ONE 'dir/' entry (mirroring `git status`), while loose untracked files
    # (under a dir that also holds tracked paths) appear individually. Unlike `git
    # status --porcelain`, ls-files does not C-quote paths that merely contain spaces,
    # so spaced names survive intact (non-ASCII still quotes — a pre-existing limit).
    # Only loose files are intent-added to the overlay below, so each untracked dir
    # renders as a single "dir/ | N files" line instead of expanding to every file.
    local -a untracked_files=() untracked_dirs=()
    local ue=
    for ue in ${(f)"$(git ls-files --others --exclude-standard --directory --no-empty-directory 2>/dev/null)"}; do
        if [[ $ue == */ ]]; then untracked_dirs+=("$ue"); else untracked_files+=("$ue"); fi
    done

    local stat_index=$(git rev-parse --git-path index 2>/dev/null)
    local tmp_index=
    {
        # `git diff` only sees tracked paths, so loose untracked files would be
        # missing from the +/- totals and the body. Fold them in WITHOUT mutating
        # the repo: copy the index to a throwaway file and `git add -N` (intent-to-
        # add) the loose paths there; against that temp index `git diff` renders each
        # as a new file with its lines as additions, aligned with the tracked
        # entries. GIT_INDEX_FILE keeps the real index and working tree untouched.
        # With no loose untracked files, stat_index points at the real index — a
        # no-op. The temp index is removed via `always`, even on an early error.
        if (( ${#untracked_files} )); then
            tmp_index=$(mktemp) || die "cannot create temp index"
            [[ -f $stat_index ]] && cp "$stat_index" "$tmp_index"
            GIT_INDEX_FILE=$tmp_index git add -N -- "${untracked_files[@]}" 2>/dev/null
            stat_index=$tmp_index
        fi

        # Compact totals for the summary line. File count and +/- line totals come
        # from the overlay diff (tracked changes + loose untracked files); each
        # collapsed untracked directory is then counted as one more "file" (its
        # contents aren't diffed, so it adds nothing to the +/- line totals — its
        # body line shows a file count instead). The summary still matches the body:
        # one counted entry per body line.
        local shortstat n_files=0 ins=0 del=0
        shortstat=$(GIT_INDEX_FILE=$stat_index git diff --shortstat $diff_target 2>/dev/null)
        [[ $shortstat =~ '([0-9]+) files? changed' ]] && n_files=$match[1]
        [[ $shortstat =~ '([0-9]+) insertion' ]] && ins=$match[1]
        [[ $shortstat =~ '([0-9]+) deletion' ]] && del=$match[1]
        (( n_files += ${#untracked_dirs} ))
        local file_word=files
        (( n_files == 1 )) && file_word=file
        STAT_SUMMARY="${n_files} ${file_word}"
        (( ins > 0 || del > 0 )) && STAT_SUMMARY+=", +${ins} -${del}"

        # Per-file body from `git diff --stat`, minus its trailing summary line
        # (those totals already sit in the summary). Width is forced to stat_width
        # (terminal width, or 80 when piped — see above) since the $(...) capture
        # hides the real terminal from git. The capture also strips git's color, so
        # force it back on when color_on.
        local stat_color=--color=never
        (( color_on )) && stat_color=--color=always
        STAT_BODY=("${(@f)$(GIT_INDEX_FILE=$stat_index git diff $stat_color --stat=$stat_width $diff_target 2>/dev/null)}")
        (( ${#STAT_BODY} > 0 )) && STAT_BODY=("${(@)STAT_BODY[1,-2]}")

        # Marker/color maps per body filename. Declared up here (not inside the
        # classification block) so the synthetic untracked-dir lines appended next
        # can register their '?' marker even when there are no tracked/loose lines.
        # wdir_sortkey overrides the within-group sort key for an entry whose display
        # name is truncated — collapsed dirs key on their FULL path so they sort in
        # `git status` order, not clustered by their leading "...".
        local -A wdir_mark wdir_col wdir_hint wdir_sortkey
        # Shared name-column width for the body. 0 means "leave git's own alignment"
        # (no untracked dirs); when dirs exist it's set below and re-pads git lines in
        # the render pass so every '|' stays aligned.
        local name_w=0

        # One synthetic stat line per collapsed untracked dir: "dir/ | N files".
        # git sizes its name column to the tracked/loose names only, so a longer dir
        # name would have to truncate to fit it. Instead, grow the shared column to
        # the longest entry (file OR dir) and re-pad the git lines, so dirs show in
        # full when the terminal has room. The growth is capped so the longest line
        # still fits stat_width; names past the cap truncate head-first ("...tail").
        # Each dir registers a '?' marker, so it groups/sorts with the loose untracked
        # files (dim green, '?' rank) in the render pass below.
        if (( ${#untracked_dirs} )); then
            # gitcol = git's current '|' column (shared by every git line); maxafter =
            # widest graph (ANSI stripped), so the column can grow only as far as keeps
            # the longest line within stat_width.
            local gitcol=0 maxafter=0 bl= bcol= aft= d=
            for bl in $STAT_BODY; do
                [[ $bl == *\|* ]] || continue
                bcol=${bl%%\|*}; (( ${#bcol} > gitcol )) && gitcol=${#bcol}
                aft=${(S)${bl#*\|}//$'\e['*m/}; (( ${#aft} > maxafter )) && maxafter=${#aft}
            done
            local avail=0
            for d in $untracked_dirs; do (( ${#d} > avail )) && avail=${#d}; done
            (( gitcol > 2 && gitcol - 2 > avail )) && avail=$(( gitcol - 2 ))
            # Cap so " name | <graph or 'N files'>" still fits stat_width.
            local suffixmax=$maxafter
            (( suffixmax < 12 )) && suffixmax=12
            local cap=$(( stat_width - 4 - suffixmax ))
            (( cap < 20 )) && cap=20
            (( avail > cap )) && avail=cap
            (( avail < 4 )) && avail=4
            name_w=$avail
            # File counts come from the full recursive untracked list.
            local -a all_untracked=(${(f)"$(git ls-files --others --exclude-standard 2>/dev/null)"})
            local disp= n= word= f= nsp= pad= keep=
            for d in $untracked_dirs; do
                disp=$d
                if (( ${#disp} > avail )); then
                    keep=$(( avail - 3 )); disp="...${disp[-keep,-1]}"
                fi
                n=0
                for f in $all_untracked; do [[ ${f[1,${#d}]} == "$d" ]] && (( n++ )); done
                word=files; (( n == 1 )) && word=file
                nsp=$(( avail - ${#disp} )); pad=
                (( nsp > 0 )) && pad=${(l:$nsp:)pad}
                STAT_BODY+=(" ${disp}${pad} | ${n} ${word}")
                wdir_mark[$disp]='?'
                wdir_col[$disp]=$'\e[2;32m'
                wdir_hint[$disp]=
                wdir_sortkey[$disp]=$d
            done
        fi

        # Prefix each body filename with a one-letter change marker, classified from
        # `git diff --raw` against the same overlay, and color-code both marker and
        # name by kind:
        #   A new (staged)  green       ? untracked    dim green
        #   D deleted       red         R/C renamed    blue
        #   M modified      default     T typechange   magenta
        #   S submodule     cyan        U unmerged     bold red
        # A pure executable-bit flip (chmod) is status M with a "| 0" stat, so it
        # would be invisible — surface it with a trailing "+x"/"-x" hint. The marker
        # is a uniform 2-char prefix on EVERY line, so git's pre-aligned '|' column
        # just shifts right and stays aligned. Markers show in plain output too; only
        # the coloring is gated on color_on. git's own +/- graph after the '|' is
        # untouched. Long paths git truncates to "...tail" are matched by that tail;
        # renames show as "old => new" (no raw path match) so are flagged R via that
        # arrow; an unmatched line falls back to a blank marker (alignment preserved).
        if (( ${#STAT_BODY} )); then
            # Loose untracked paths were intent-to-added into the overlay, so `git
            # diff` reports them as A like a staged-new file; re-split them as ?.
            local -A is_untracked
            local u
            for u in $untracked_files; do is_untracked[$u]=1; done
            # Conflicted paths show as plain M in `git diff --raw`, so take the
            # unmerged set from porcelain status codes (DD/AU/UD/UA/DU/AA/UU) instead.
            local -A is_unmerged
            local pl
            for pl in ${(f)porcelain}; do
                case ${pl[1,2]} in
                    DD|AU|UD|UA|DU|AA|UU) is_unmerged[${pl[4,-1]}]=1 ;;
                esac
            done

            local raw_line
            while IFS= read -r raw_line; do
                [[ -z $raw_line ]] && continue
                local -a mf=(${=${raw_line%%$'\t'*}})   # :oldmode newmode oldsha newsha STATUS
                local p=${raw_line##*$'\t'}             # path (new path for renames)
                local om=${mf[1]#:} nm=${mf[2]} st=${mf[5]} mark= col= hint=
                if [[ $om == 160000 || $nm == 160000 ]]; then
                    mark=S col=$'\e[36m'                  # submodule -> cyan
                else
                    mark=${st:0:1}                        # A/M/D/R/C/T/U...
                    case $mark in
                        A) if [[ -n ${is_untracked[$p]} ]]; then
                               mark='?' col=$'\e[2;32m'   # untracked -> dim green
                           else
                               col=$'\e[32m'              # staged new -> green
                           fi ;;
                        D)   col=$'\e[31m' ;;             # deleted -> red
                        R|C) col=$'\e[34m' ;;             # renamed/copied -> blue
                        T)   col=$'\e[35m' ;;             # typechange (file<->symlink) -> magenta
                        U)   col=$'\e[1;31m' ;;           # unmerged/conflict -> bold red
                    esac
                    # Executable-bit flip that --stat renders as "| 0" (status M).
                    if [[ $mark == M && $om != $nm && $om != 000000 && $nm != 000000 ]]; then
                        [[ $nm == 100755 ]] && hint=' +x'
                        [[ $nm == 100644 && $om == 100755 ]] && hint=' -x'
                    fi
                fi
                # A conflicted path overrides everything else: unmerged -> bold red U.
                [[ -n ${is_unmerged[$p]} ]] && { mark=U; col=$'\e[1;31m'; hint=; }
                wdir_mark[$p]=$mark
                wdir_col[$p]=$col
                wdir_hint[$p]=$hint
            done < <(GIT_INDEX_FILE=$stat_index git diff --raw $diff_target 2>/dev/null)

            if (( ${#wdir_mark} )); then
                local creset=$'\e[0m'
                # Render each line, tagging it with a signal rank and its filename;
                # then re-emit the body grouped by rank (A ? M D R T S U, then anything
                # else) so the colors cluster, sorting by filename within each group.
                local -a r_line=() r_rank=() r_name=()
                local sline= before= after= lead= body= trail= nf= mark= col= hint= cp= rank= rendered= tw= sp=
                for sline in $STAT_BODY; do
                    before=${sline%%\|*}            # " name<pad> " up to the first '|'
                    if [[ $before == $sline ]]; then
                        r_line+=("$sline"); r_rank+=(9); r_name+=("$sline"); continue   # no '|': keep, sort last
                    fi
                    after=${sline#"$before"}        # "| graph..." with git's colors
                    lead=${before%%[! ]*}           # leading spaces
                    body=${before#"$lead"}          # name + trailing pad
                    trail=${body##*[! ]}            # trailing spaces
                    nf=${body%"$trail"}             # the display name
                    if (( name_w > 0 )); then        # re-pad to the shared column so a
                        tw=$(( name_w - ${#nf} + 1 ))   # collapsed dir (maybe wider than
                        (( tw < 1 )) && tw=1            # git's own names) and the git
                        trail=${(l:$tw:)sp}            # lines keep one aligned '|'
                    fi
                    mark=${wdir_mark[$nf]}
                    col=${wdir_col[$nf]}
                    hint=${wdir_hint[$nf]}
                    if [[ -z $mark ]]; then
                        if [[ $nf == *" => "* ]]; then
                            mark=R col=$'\e[34m'    # rename: stat shows "old => new" -> blue
                        elif [[ $nf == ...* ]]; then
                            for cp in ${(k)wdir_mark}; do   # truncated path: match by tail
                                if [[ $cp == *"${nf#...}" ]]; then
                                    mark=${wdir_mark[$cp]}
                                    col=${wdir_col[$cp]}
                                    hint=${wdir_hint[$cp]}
                                    break
                                fi
                            done
                        fi
                        [[ -z $mark ]] && mark=' '  # fallback: blank marker, keep alignment
                    fi
                    # Dim the mode hint so it reads as a subordinate annotation.
                    (( color_on )) && [[ -n $hint ]] && hint=$'\e[2m'"${hint}${creset}"
                    if (( color_on )) && [[ -n $col ]]; then
                        rendered="${lead}${col}${mark}${creset} ${col}${nf}${creset}${trail}${after}${hint}"
                    else
                        rendered="${lead}${mark} ${nf}${trail}${after}${hint}"
                    fi
                    case $mark in
                        A)   rank=1 ;;
                        '?') rank=2 ;;
                        M)   rank=3 ;;
                        D)   rank=4 ;;
                        R|C) rank=5 ;;
                        T)   rank=6 ;;
                        S)   rank=7 ;;
                        U)   rank=8 ;;
                        *)   rank=9 ;;
                    esac
                    r_line+=("$rendered"); r_rank+=("$rank"); r_name+=("${wdir_sortkey[$nf]:-$nf}")
                done
                # Order within a rank by filename in C/byte order, matching how git
                # sorts `git status` / `git diff --stat`. LC_COLLATE=C avoids locale
                # collation (which would sort e.g. 'g' before 'P' or mishandle
                # punctuation); it's a function-local, restored on return.
                local LC_COLLATE=C
                local -a marked=()
                local g= i=
                for g in 1 2 3 4 5 6 7 8 9; do
                    # Key each line with its (full-path) sort name plus a tab, sort,
                    # then strip the key back off.
                    local -a group=()
                    for ((i = 1; i <= ${#r_line}; i++)); do
                        [[ ${r_rank[i]} == $g ]] && group+=("${r_name[i]}"$'\t'"${r_line[i]}")
                    done
                    group=("${(o)group[@]}")
                    local entry=
                    for entry in $group; do
                        marked+=("${entry#*$'\t'}")
                    done
                done
                STAT_BODY=("${marked[@]}")
            fi
        fi
    } always {
        [[ -n $tmp_index ]] && rm -f "$tmp_index"
    }
}

function main {
    # Option parsing (zparseopts is a zsh builtin; -K keeps the ARG_LIMIT default
    # when -n is not passed). Operates on main's own positional params ("$@").
    local -a ARG_LIMIT=(1) ARG_BASE=() ARG_UNCOMMITTED=() ARG_HELP=()
    zparseopts -D -E -K -- \
        {n,-limit}:=ARG_LIMIT \
        -base:=ARG_BASE \
        {u,-uncommitted}=ARG_UNCOMMITTED \
        {h,-help}=ARG_HELP \
        || { smartlog_usage >&2; exit 2; }
    (( ${#ARG_HELP} )) && { smartlog_usage; exit 0; }

    NOW=$EPOCHSECONDS
    local today
    strftime -s today '%Y-%m-%d' $NOW
    strftime -rs TODAY_MIDNIGHT '%Y-%m-%d %H:%M:%S' "$today 00:00:00"
    strftime -s CURRENT_YEAR '%Y' $NOW

    # For sapling's compact-public-node rule: a public, non-HEAD commit authored
    # by someone else renders metadata-only. Compared against the configured user.
    local my_email
    my_email=$(git config user.email 2>/dev/null)

    # The active local branch (HEAD's) is shown with a trailing "*", like sapling's
    # active bookmark — but only when no remote branch of the same name exists. If
    # one does, sapling shows just the remote bookmark (e.g. on `master`, only
    # origin/master appears, never master*). Detached HEAD has no active branch.
    ACTIVE_BRANCH=
    local cur_branch
    cur_branch=$(git symbolic-ref --quiet --short HEAD 2>/dev/null)
    if [[ -n $cur_branch ]] &&
       [[ -z $(git for-each-ref --count=1 --format=x "refs/remotes/*/${cur_branch}" 2>/dev/null) ]]; then
        ACTIVE_BRANCH="${cur_branch}*"
    fi

    local limit=${ARG_LIMIT[-1]}
    local base_arg=
    (( ${#ARG_BASE} > 0 )) && base_arg=${ARG_BASE[-1]}

    local base_ref
    if [[ -n $base_arg ]]; then
        base_ref=$(resolve_base "$base_arg") ||
            die "Cannot resolve --base $base_arg"
    else
        base_ref=$(resolve_base "") ||
            die "Cannot find a public base ref (no remote trunk, @{u}, or local main/master)"
    fi

    local head_sha
    head_sha=$(git rev-parse HEAD 2>/dev/null) ||
        die "HEAD is not a valid commit"

    local merge_base
    merge_base=$(git merge-base HEAD "$base_ref" 2>/dev/null) ||
        die "No merge-base between HEAD and $base_ref"

    # Uncommitted working-tree changes render as a synthetic "Uncommitted changes"
    # node on top of HEAD; the @ marker moves there, since that's where the working
    # copy actually is. The stat block is computed by uncommitted_stat (the very
    # same code the standalone `git-smartstat` runs) — we just consume its
    # REPLY-style globals. Color matches the C_* palette gate below.
    local has_changes=0 wdir_summary=
    local -a wdir_stat
    if (( ${#ARG_UNCOMMITTED} )); then
        local color_on=0
        [[ -t 1 && -z $NO_COLOR ]] && color_on=1
        uncommitted_stat $color_on 4   # body lines are indented "  │ " in the node
        has_changes=$STAT_HAS_CHANGES
        wdir_summary=$STAT_SUMMARY
        wdir_stat=("${STAT_BODY[@]}")
    fi

    local -a drafts publics
    if [[ $head_sha != $merge_base ]]; then
        drafts=("${(@f)$(git rev-list --first-parent HEAD "^$merge_base")}")
    fi
    publics=("${(@f)$(git rev-list --first-parent "$base_ref" -n $limit)}")
    # If base_ref is ahead of HEAD's branch, anchor public column at merge_base instead.
    if [[ ${publics[(Ie)$merge_base]} -eq 0 ]]; then
        publics=("${(@f)$(git rev-list --first-parent "$merge_base" -n $limit)}")
    fi

    local C_PUBLIC_HASH= C_DRAFT_HASH= C_HEAD_TEXT= C_REF= C_BRANCH= C_RESET=
    if [[ -t 1 && -z $NO_COLOR ]]; then
        C_PUBLIC_HASH=$'\e[33m'
        C_DRAFT_HASH=$'\e[93;1m'
        C_HEAD_TEXT=$'\e[35m'
        C_REF=$'\e[32m'
        C_BRANCH=$'\e[33m'
        C_RESET=$'\e[0m'
    fi

    local -a all_shas
    all_shas=("${drafts[@]}" "${publics[@]}")
    (( ${#all_shas} == 0 )) && die "Nothing to display"

    local commit_data
    commit_data=$(git log --no-walk=unsorted --abbrev=10 --decorate=full \
        --pretty=format:'%h%x1f%at%x1f%al%x1f%ae%x1f%D%x1f%s' "${all_shas[@]}")

    local -a hashes epochs authors author_emails refs subjects
    local h e a ae r s
    while IFS=$'\x1f' read -r h e a ae r s; do
        [[ -z $h ]] && continue
        hashes+=("$h")
        epochs+=("$e")
        authors+=("$a")
        author_emails+=("$ae")
        refs+=("$r")
        subjects+=("$s")
    done <<< "$commit_data"

    local n_drafts=${#drafts}
    local total=$((n_drafts + ${#publics}))

    # Synthetic wdir node, drawn above the stack: @ marker, draft-colored label, the
    # change summary in HEAD-text color. It connects straight down into the draft
    # column when HEAD is a draft, otherwise it bends (╭─╯) into the public column.
    if (( has_changes )); then
        local wdir_text_reset=
        [[ -n $C_HEAD_TEXT ]] && wdir_text_reset=$C_RESET
        print -r -- "  @  ${C_DRAFT_HASH}Uncommitted changes${C_RESET}${C_HEAD_TEXT}  ${wdir_summary}${wdir_text_reset}"
        # stat_line already starts with one space (git's --stat lead); add one more
        # so the marker sits 2 cols past the │ spine, aligning with commit text
        # (│  subject) and the node header (@  Uncommitted changes).
        local stat_line
        for stat_line in $wdir_stat; do
            print -r -- "  │ ${stat_line}"
        done
        if (( n_drafts > 0 )); then
            print -r -- "  │"
        else
            print -r -- "╭─╯"
            print -r -- "│"
        fi
    fi

    local i
    for ((i=1; i<=total; i++)); do
        local sha=${all_shas[$i]}
        local hash=${hashes[$i]}
        local epoch=${epochs[$i]}
        local author=${authors[$i]}
        local author_email=${author_emails[$i]}
        local refs_raw=${refs[$i]}
        local subject=${subjects[$i]}

        local is_draft=0 is_last_draft=0 is_last_public=0
        (( i <= n_drafts )) && is_draft=1
        (( i == n_drafts && n_drafts > 0 )) && is_last_draft=1
        (( i == total )) && is_last_public=1

        local symbol=o
        local hash_color=$C_PUBLIC_HASH
        local text_color=
        (( is_draft )) && hash_color=$C_DRAFT_HASH
        local is_head=0
        if [[ $sha == $head_sha ]]; then
            is_head=1
            # With uncommitted changes the @ marker belongs to the wdir node above;
            # HEAD stays a normal node (but is_head still forces a full, non-compact
            # header so its author/subject keep showing).
            if (( ! has_changes )); then
                symbol=@
                text_color=$C_HEAD_TEXT
            fi
        fi

        # Compact public node: public (not a draft), not HEAD, authored by someone
        # else → metadata-only (no author, no subject). See header.
        local is_compact=0
        if (( ! is_draft && ! is_head )) && [[ $author_email != $my_email ]]; then
            is_compact=1
        fi

        reltime $epoch
        local time_str=$REPLY
        filter_refs "$refs_raw"
        local refs_clean=$REPLY
        local ref_display=
        if [[ -n $refs_clean ]]; then
            # Color each ref by kind, matching sapling: the active local branch
            # ($ACTIVE_BRANCH, the "name*" token) is yellow, remote bookmarks green.
            # Quote the RHS so the trailing "*" is matched literally, not as a glob.
            # Both locals MUST carry an assignment: a bare `local rt` / `local -a
            # colored` re-run in the same function scope neither resets the prior
            # iteration's value nor stays silent — zsh echoes the stale value.
            local -a colored=()
            local rt=
            for rt in ${(s: :)refs_clean}; do
                if [[ $rt == "$ACTIVE_BRANCH" ]]; then
                    colored+=("${C_BRANCH}${rt}${C_RESET}")
                else
                    colored+=("${C_REF}${rt}${C_RESET}")
                fi
            done
            ref_display="  ${(j: :)colored}"
        fi

        local indent=
        (( is_draft )) && indent="  "

        local text_reset=
        [[ -n $text_color ]] && text_reset=$C_RESET

        local author_seg="  ${author}"
        (( is_compact )) && author_seg=
        local subject_body="  ${text_color}${subject}${text_reset}"
        (( is_compact )) && subject_body=

        print -r -- "${indent}${symbol}  ${hash_color}${hash}${C_RESET}${text_color}  ${time_str}${author_seg}${text_reset}${ref_display}"

        if (( is_last_draft )); then
            print -r -- "╭─╯${subject_body}"
            print -r -- "│"
        elif (( is_last_public )); then
            print -r -- "${indent}│${subject_body}"
            print -r -- "~"
        else
            print -r -- "${indent}│${subject_body}"
            print -r -- "${indent}│"
        fi
    done
}

function smartstat_main {
    # Standalone entry point (invoked as git-smartstat): print just the uncommitted
    # stat block — a plain summary line followed by the per-file body — or nothing
    # when the working tree is clean. --color WHEN is auto (default), always, never.
    local -a ARG_COLOR=(auto) ARG_HELP=()
    zparseopts -D -E -K -- \
        -color:=ARG_COLOR \
        {h,-help}=ARG_HELP \
        || { smartstat_usage >&2; exit 2; }
    (( ${#ARG_HELP} )) && { smartstat_usage; exit 0; }
    # -E leaves anything unrecognized (e.g. --bogus) in the positionals; we take no
    # positional args, so treat leftovers as a usage error.
    (( $# )) && { print -ru2 -- "$PROG: unexpected argument: $1"; smartstat_usage >&2; exit 2; }

    git rev-parse --is-inside-work-tree >/dev/null 2>&1 ||
        die "not a git repository"

    # zparseopts keeps the "=" of the --color=WHEN form (--color WHEN gives a bare
    # value), so strip one leading "=" before matching.
    local when=${ARG_COLOR[-1]#=}
    local color_on=0
    case $when in
        always) color_on=1 ;;
        never)  color_on=0 ;;
        auto)   [[ -t 1 && -z $NO_COLOR ]] && color_on=1 ;;
        *)      print -ru2 -- "$PROG: invalid --color: $when (use auto, always, or never)"
                exit 2 ;;
    esac

    uncommitted_stat $color_on
    (( STAT_HAS_CHANGES )) || return 0
    print -r -- "$STAT_SUMMARY"
    local line
    for line in "${STAT_BODY[@]}"; do
        print -r -- "$line"
    done
}

# Multi-call dispatch on the invocation name: git-smartstat runs only the stat
# block, anything else (git-smartlog) runs the full smartlog.
case $PROG in
    git-smartstat|smartstat) smartstat_main "$@" ;;
    *)                       main "$@" ;;
esac
